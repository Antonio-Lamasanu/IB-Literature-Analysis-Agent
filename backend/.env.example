# Optional explicit path to Tesseract executable.
# Windows example: C:\Program Files\Tesseract-OCR\tesseract.exe
# macOS/Linux example: /usr/local/bin/tesseract
TESSERACT_CMD=

# OCR language(s) installed in Tesseract. Example: eng or eng+spa
TESSERACT_LANG=eng

# Enable OCR post-processing cleanup (page markers, header/footer stripping, line merge).
OCR_CLEANING=1

# Header/footer stripping settings for OCR cleanup.
OCR_HEADER_FOOTER_LINES=3
OCR_HEADER_FOOTER_FREQ=0.35

# Optional OCR cleanup toggles.
OCR_SAFE_CORRECTIONS=0
OCR_HEADER_PATTERN_STRIP=1
OCR_HEADING_MARKERS=1

# Set to 1 to emit per-page extraction debug logs to the backend server logs.
PDF_EXTRACT_DEBUG=0

# Chunking settings for /api/process-pdf-chunks.
CHUNK_TARGET_TOKENS=500
CHUNK_OVERLAP_TOKENS=100
CHUNK_MIN_TOKENS=200
CHUNK_MAX_TOKENS=800
CHUNK_INCLUDE_RAW=0
CHUNK_FILTER_FOR_EMBEDDING=0
CHUNK_EMBED_MIN_TOKENS=120
CHUNK_EMBED_EXCLUDE_SECTION_TYPES=toc,front_matter
CHUNK_DROP_NOISE_PARAS=1

# Heuristic threshold for deciding native text vs OCR.
NATIVE_CHAR_THRESHOLD=200

# Max upload size in MB enforced by backend while streaming upload.
MAX_UPLOAD_MB=500

# Set to 1 to keep generated outputs in backend/outputs for debugging.
KEEP_OUTPUT_FILES=0

# LLM chat settings.
# Place .gguf files in backend/models/ (relative to backend/ working directory).
# The frontend model selector will auto-discover all .gguf files in that directory.
LLM_ENABLED=1
LLM_MODEL_PATH=./models/gemma-3-4b-it-Q4_K_M.gguf
LLM_N_CTX=2048
LLM_N_THREADS=4
LLM_MAX_TOKENS=512
LLM_TEMPERATURE=0.2
CHAT_MAX_HISTORY_MESSAGES=10

# Filesystem-backed chat history settings.
# CHAT_RETRIEVAL_MODE supports: chunks_only, combined, history_first
# Leave CHAT_HISTORY_STORAGE_DIR blank to use backend/outputs/chat_history.
CHAT_HISTORY_ENABLED=1
CHAT_RETRIEVAL_MODE=chunks_only
CHAT_HISTORY_REUSE_THRESHOLD=2.75
CHAT_HISTORY_MAX_CANDIDATES=12
CHAT_HISTORY_MAX_EXCERPTS=2
CHAT_HISTORY_STORAGE_DIR=

# Corpus lookup cache TTL in days. Set to 0 to disable caching (force fresh API calls).
CORPUS_CACHE_TTL_DAYS=30

# Corpus lookup — Option C (LLM API fallback, dev use only).
# Fires when Option A/B score is below CORPUS_OPTION_C_THRESHOLD.
# Manually triggered via POST /api/documents/{id}/resolve-corpus.
CORPUS_OPTION_C_THRESHOLD=0.4
CORPUS_LLM_API_URL=
CORPUS_LLM_API_KEY=
CORPUS_LLM_MODEL=

# Prompt Router (System 2) — automatic base_knowledge vs rag selection.
ROUTER_CONFIDENCE_THRESHOLD=0.65
ROUTER_RAG_SEMANTIC_THRESHOLD=0.25  # fallback threshold used when context-need scoring is unavailable
ROUTER_DEFAULT_MODE=rag
# Context-need scoring (dataset-based query scoring).
ROUTER_CONTEXT_NEED_THRESHOLD=0.45  # queries scoring above this use RAG
ROUTER_CONTEXT_NEED_TOP_K=5         # number of nearest dataset questions to average

# Comma-separated list of allowed frontend origins for CORS.
# If you change the Vite dev server port, update this list to match.
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:5174,http://127.0.0.1:5174
